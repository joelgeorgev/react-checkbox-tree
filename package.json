{
  "name": "react-checkbox-tree",
  "version": "1.0.0",
  "description": "A react app showcasing a simple checkbox tree component.",
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "styled-components": "^5.3.5"
  },
  "devDependencies": {
    "@testing-library/react": "^13.3.0",
    "@testing-library/user-event": "^14.4.3",
    "@types/react": "^18.0.18",
    "@types/react-dom": "^18.0.6",
    "@types/styled-components": "^5.1.26",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "gh-pages": "^4.0.0",
    "jsdom": "^28.1.0",
    "oxlint": "^1.50.0",
    "prettier": "^2.7.1",
    "typescript": "^4.8.2",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "npm run check:format && npm run check:types && npm run check:lint",
    "check:format": "prettier --check \"./**/*.{html,ts,tsx,json,yml,md}\"",
    "check:types": "tsc",
    "check:types:watch": "npm run check:types -- --watch",
    "check:lint": "oxlint",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d build"
  },
  "repository": "https://github.com/joelgeorgev/react-checkbox-tree",
  "keywords": [
    "typescript",
    "React",
    "reactjs",
    "checkbox",
    "tree",
    "normalize"
  ],
  "author": "Joel George V",
  "homepage": "https://joelgeorgev.github.io/react-checkbox-tree",
  "license": "MIT"
}
